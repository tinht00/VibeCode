# === Background Remover - Cấu hình môi trường ===
# Copy file này thành .env và chỉnh sửa theo nhu cầu:
#   cp .env.example .env

# Môi trường: "development" | "production"
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# CORS - Danh sách origins được phép (phân cách bằng dấu phẩy)
# Development: chỉ cho phép Vite dev server
# Production: thay bằng domain thật
CORS_ORIGINS=http://localhost:5173

# Session
# Thời gian sống session (giây) - mặc định 1 giờ
SESSION_TTL_SECONDS=3600
# Số session tối đa đồng thời
MAX_SESSIONS=100

# Logging: "DEBUG" | "INFO" | "WARNING" | "ERROR"
LOG_LEVEL=INFO
