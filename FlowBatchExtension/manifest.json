{
  "manifest_version": 3,
  "name": "Flow Batch Generator",
  "version": "1.0.0",
  "description": "Tự động batch generate ảnh trên Flow và tải các ảnh đã chọn về máy.",
  "permissions": ["activeTab", "tabs", "scripting", "storage", "downloads", "debugger", "sidePanel"],
  "host_permissions": ["https://labs.google/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Flow Batch Generator"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.js"],
      "matches": ["https://labs.google/*"]
    }
  ]
}
